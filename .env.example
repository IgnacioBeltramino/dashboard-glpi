GLPI_URL=https://tu-servidor/apirest.php
GLPI_APP_TOKEN=tu_app_token_aqui
GLPI_USER_TOKEN=tu_user_token_aqui

# Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui

# Chat ID del jefe (recibe todas las notificaciones)
TELEGRAM_BOSS_CHAT_ID=123456789

# Tecnicos: formato glpi_user_id:telegram_chat_id separados por coma
# El tecnico asignado al ticket recibe la notificacion ademas del jefe
# Ejemplo: 42:123456789,87:987654321
# Entradas con chat_id vacio (ej: 87:) son ignoradas automaticamente por el parser
TELEGRAM_TECH_IDS=

# Puertos (cambiar si el puerto por defecto ya esta en uso en tu maquina)
BACKEND_PORT=8000
FRONTEND_PORT=5173
